---
import { Languages, Search } from "@lucide/astro";
import { profile } from "@data/profile";

const navLinks = [
  { label: "Resume", href: "/resume/zh/", num: "01" },
  { label: "Capabilities", href: "/#capabilities", num: "04" },
  { label: "Labs", href: "/#labs", num: "05" },
  { label: "Writing", href: "/blog/", num: "02" },
  { label: "Contact", href: "/#contact" }
];
---

<div class="topbar" data-od-id="topbar">
  <div class="container topbar-inner">
    <span><b>PR / 2026</b> · Vol. 01 / Resume Nº 01</span>
    <span class="mid">
      <span>Filed under <b class="coral">Resume · Automation</b></span>
      <span>Astro · MDX · GitHub Pages</span>
    </span>
    <span class="right">
      <a class="topbar-link" href="https://peterria.github.io/">
        <span class="pulse"></span>Live · username.github.io
      </a>
      <button class="topbar-button" type="button" data-lang-toggle aria-label="Switch language">
        <Languages size={13} />
        <span><b>中文</b> · EN</span>
      </button>
    </span>
  </div>
</div>

<header class="nav" data-od-id="nav">
  <div class="container nav-inner">
    <a href="/#top" class="brand" aria-label="PeterRia home">
      <span class="brand-mark">P</span>
      <span>PeterRia</span>
      <span class="brand-meta"><b>Resume Nº 01</b>China / Remote / Open</span>
    </a>

    <nav aria-label="Primary navigation">
      <ul class="nav-links">
        {navLinks.map((item) => (
          <li>
            <a href={item.href}>
              {item.label}
              {item.num && <span class="num">{item.num}</span>}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="nav-side">
      <button class="nav-cta ghost" type="button" data-command-open aria-label="Search">
        <Search size={13} />
        Search
      </button>
      <a
        class="nav-cta"
        href={profile.zh.github}
        data-github-stars
        data-github-repo="PeterRia/PeterRia.github.io"
        aria-label="Open GitHub repository"
      >
        Star · 0
      </a>
      <span class="status-dot" aria-hidden="true"></span>
    </div>
  </div>
</header>
