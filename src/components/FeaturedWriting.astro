---
import { ArrowUpRight } from "@lucide/astro";
import type { CollectionEntry } from "astro:content";

interface Props {
  posts: CollectionEntry<"blog">[];
}

const { posts } = Astro.props;
---

<section class="section-band writing-band" aria-labelledby="writing-title">
  <div class="section-heading reveal">
    <p class="eyebrow" data-lang="zh">博客</p>
    <p class="eyebrow" data-lang="en">Writing</p>
    <h2 id="writing-title" data-lang="zh">少量但持续沉淀的文章</h2>
    <h2 id="writing-title-en" data-lang="en">A compact writing shelf</h2>
  </div>

  <div class="post-grid">
    {posts.map((post, index) => (
      <article class="post-card reveal" style={`--delay: ${index * 80}ms`}>
        <p class="post-meta">
          <span>{post.data.pubDate.toLocaleDateString(post.data.lang === "zh" ? "zh-CN" : "en-US")}</span>
          <span>{post.data.lang.toUpperCase()}</span>
        </p>
        <h3>{post.data.title}</h3>
        <p>{post.data.description}</p>
        <div class="tag-row">
          {post.data.tags.map((tag) => <span>{tag}</span>)}
        </div>
        <a class="text-link" href={`/blog/${post.slug}/`}>
          <span data-lang="zh">打开文章</span>
          <span data-lang="en">Open article</span>
          <ArrowUpRight size={16} />
        </a>
      </article>
    ))}
  </div>
</section>
