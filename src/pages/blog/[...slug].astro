---
import { getCollection, type CollectionEntry } from "astro:content";
import { ArrowLeft } from "@lucide/astro";
import BaseLayout from "@layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const posts = (await getCollection("blog")).filter((post) => !post.data.draft);

  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post }
  }));
}

interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;
const { Content } = await post.render();
---

<BaseLayout title={`${post.data.title} | PeterRia`} description={post.data.description} lang={post.data.lang}>
  <article class="article-shell">
    <a class="text-link back-link" href="/blog/">
      <ArrowLeft size={16} />
      <span data-lang="zh">返回博客</span>
      <span data-lang="en">Back to blog</span>
    </a>
    <header class="article-header reveal">
      <p class="post-meta">
        <span>{post.data.pubDate.toLocaleDateString(post.data.lang === "zh" ? "zh-CN" : "en-US")}</span>
        <span>{post.data.lang.toUpperCase()}</span>
      </p>
      <h1>{post.data.title}</h1>
      <p>{post.data.description}</p>
      <div class="tag-row">
        {post.data.tags.map((tag) => <span>{tag}</span>)}
      </div>
    </header>
    <div class="prose reveal">
      <Content />
    </div>
  </article>
</BaseLayout>
